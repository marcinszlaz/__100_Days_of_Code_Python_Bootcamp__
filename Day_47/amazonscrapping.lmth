    .aplus-v2 .container-with-background-image {
        width: 100%;
        height: 100%;
        background-repeat: no-repeat;
        background-size: cover;
    }
</style>
  <script type="application/javascript">
    function logShoppableMetrics(moduleName, showsAddToCart) {
