    <div class="a-section a-spacing-small a-spacing-top-small">  <table class="a-normal a-spacing-micro" role="list">  <tr class="a-spacing-small po-brand" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Marka</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Instant Pot</span>   </td> </tr>  <tr class="a-spacing-small po-capacity" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Pojemność</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">5,7 Litry</span>   </td> </tr>  <tr class="a-spacing-small po-material" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Materiał</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Stal nierdzewna</span>   </td> </tr>  <tr class="a-spacing-small po-color" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Kolor</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Black/Stainless Steel</span>   </td> </tr>  <tr class="a-spacing-small po-finish_type" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Typ wykończenia</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Chrom</span>   </td> </tr>  <tr class="a-spacing-small po-item_depth_width_height" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Wymiary produktu</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">33,5gł. x 31szer. x 31,7wys. cm</span>   </td> </tr>  <tr class="a-spacing-small po-special_feature" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Funkcja specjalna</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Automatyczne wyłączanie, Programowalny, Ustawienie utrzymywania ciepła</span>   </td> </tr>  <tr class="a-spacing-small po-wattage" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Moc</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">1000 W</span>   </td> </tr>  <tr class="a-spacing-small po-item_weight" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Waga produktu</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">5,4 Kilogramy</span>   </td> </tr>  <tr class="a-spacing-small po-control_method" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Metoda kontroli</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Dotykowy</span>   </td> </tr>    </table>  </div> </div> <div id="poToggleButton" class="a-expander-header a-expander-partial-collapse-header"><div class="a-expander-content-fade"></div><a href="javascript:void(0)" role="button" data-action="a-expander-toggle" class="a-declarative" data-a-expander-toggle="{&quot;allowLinkDefault&quot;:true, &quot;expand_prompt&quot;:&quot;Pokaż więcej&quot;, &quot;collapse_prompt&quot;:&quot;Pokaż mniej&quot;}"><i class="a-icon a-icon-extender-expand"></i><span class="a-expander-prompt">Pokaż więcej</span></a></div> </div>                                   </div>
