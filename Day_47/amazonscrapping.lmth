        <script type="a-state" data-a-state="{&quot;key&quot;:&quot;twister-bo-swatch-captions-data&quot;}">{"ALM":"Sklepy lokalne","RENEWED_TIER_1":"Odnowione","RENEWED_TIER_4":"Odnowione","SNS":"Subskrybuj i oszczędzaj","USED":"Używane","RENEWED_TIER_3":"Odnowione","RENEWED_TIER_2":"Odnowione","PRIME_SAVINGS_UPSELL":"W ramach członkostwa w programie Prime"}</script>  <script type="text/javascript">
    P.register('twister-plus-desktop-twister-mark-render', function(){
        if (typeof window.markFeatureRender === 'function') {
            var nonSingletonDimensionLength =2;
            var options = {};
            if (nonSingletonDimensionLength === 0) {
                options.isInteractive = false;
            } else {
                var twisterComponent = "twister-plus-new-desktopTwister";
                options.hasComponents = true;
                options.components = [{
                    name: twisterComponent
